SECRET_KEY=replace-with-a-long-random-secret-key-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

DATABASE_URL=postgresql+psycopg://travelbuddy:travelbuddy@postgres:5432/travelbuddy
REDIS_URL=redis://redis:6379/0

JWT_COOKIE_NAME=access_token
CSRF_COOKIE_NAME=csrf_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_PATH=/
COOKIE_DOMAIN=

ENV=dev
DEBUG=true
APP_BASE_URL=http://127.0.0.1:8000
FRONTEND_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# Frontend (Vite)
VITE_API_BASE_URL=/
VITE_MEDIA_BASE_URL=/
VITE_DEV_PROXY_TARGET=http://backend:8000
VITE_ALLOWED_HOSTS=127.0.0.1,localhost
