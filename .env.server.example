SECRET_KEY=replace-with-a-long-random-secret-key-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

DATABASE_URL=postgresql+psycopg://travelbuddy:travelbuddy@postgres:5432/travelbuddy
REDIS_URL=redis://redis:6379/0

JWT_COOKIE_NAME=access_token
CSRF_COOKIE_NAME=csrf_token
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_PATH=/
COOKIE_DOMAIN=fishingteam.su

ENV=prod
DEBUG=false
APP_BASE_URL=https://fishingteam.su
FRONTEND_ORIGINS=https://fishingteam.su
CORS_ALLOW_ORIGINS=["https://fishingteam.su"]

# Frontend (Vite preview / static mode behind nginx)
VITE_API_BASE_URL=/
VITE_MEDIA_BASE_URL=/
VITE_DEV_PROXY_TARGET=http://backend:8000
VITE_ALLOWED_HOSTS=fishingteam.su,localhost,127.0.0.1
