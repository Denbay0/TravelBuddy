# Shared template. Copy one of the environment-specific examples below:
#   cp .env.local.example .env.local
#   cp .env.server.example .env.server

SECRET_KEY=replace-with-a-long-random-secret-key-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

JWT_COOKIE_NAME=access_token
CSRF_COOKIE_NAME=csrf_token
COOKIE_PATH=/
COOKIE_SAMESITE=lax

# FastAPI runtime
ENV=dev
DEBUG=false

# Data stores
DATABASE_URL=postgresql+psycopg://travelbuddy:travelbuddy@postgres:5432/travelbuddy
REDIS_URL=redis://redis:6379/0

## Optional bootstrap admin (legacy flow: created/promoted at startup)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_USERNAME=admin

# Simple admin login (used directly by /admin/auth/login in ENV=dev)
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
ADMIN_EMAIL=admin@travelbuddy.dev

# Frontend admin defaults (dev only)
VITE_ADMIN_LOGIN=admin
VITE_ADMIN_PASSWORD=admin

# CORS/cookies and public URLs are environment-specific.
# See .env.local.example and .env.server.example

GEOAPIFY_API_KEY=replace-with-geoapify-key
VITE_GEOAPIFY_MAP_KEY=replace-with-geoapify-key
VITE_GEOAPIFY_STYLE_URL=https://maps.geoapify.com/v1/styles/osm-carto/style.json?apiKey=replace-with-geoapify-key
